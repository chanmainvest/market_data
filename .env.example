# Postgres (TimescaleDB)
POSTGRES_USER=mdata
POSTGRES_PASSWORD=mdata
POSTGRES_DB=mdata
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Set MARKET_DATA_DB=1 to enable dual-write from scrapers into Postgres.
# When unset, scrapers stay CSV-only (backwards compatible).
MARKET_DATA_DB=

# Optional SOCKS5 proxy pool for Yahoo Finance scrapers to avoid per-IP rate
# limiting (HTTP 429). Comma-separated SSH host aliases — each scraper opens
# one `ssh -D` tunnel per host and round-robins requests across them.
# Hosts must be resolvable aliases in ~/.ssh/config with key auth.
# Available hosts: hevangel.com, oc1/2/3/4.hevangel.com, horace.org, serv00
YAHOO_PROXY_HOSTS=             # e.g. "oc1.hevangel.com,oc2.hevangel.com,serv00"

# Optional: override the full DB url (otherwise built from POSTGRES_* above)
# MARKET_DATA_DB_URL=postgresql+psycopg://mdata:mdata@localhost:5433/mdata

# FastAPI backend
API_HOST=127.0.0.1
API_PORT=8000

# Frontend (Vite dev server)
WEB_PORT=3000
